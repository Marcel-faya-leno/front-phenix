# .env.example - PHENIX-TECH-SERVICES Frontend
# Copier ce fichier en .env.local et le personnaliser pour le déploiement local

# API BACKEND - Render
VITE_API_BASE_URL=https://backend-phenix.onrender.com/api
VITE_BACKEND_URL=https://backend-phenix.onrender.com

# FRONTEND URL
VITE_FRONTEND_URL=https://front-phenix.netlify.app

# ENVIRONNEMENT
VITE_ENV=production
NODE_ENV=production

# FEATURES
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SOCKET_IO=true
